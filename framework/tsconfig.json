{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@react-cms/framework": ["./index.ts"],
      "@react-cms/framework/*": ["./src/*"],
      "@react-cms/cms": ["../cms/index.ts"],
      "@react-cms/cms/*": ["../cms/src/*"],
      "@react-cms/copies": ["../copies/index.ts"],
      "@react-cms/copies/*": ["../copies/src/*"]
    }
  },
  "include": ["src", "index.ts"]
}
