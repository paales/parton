{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@parton/framework": ["./index.ts"],
      "@parton/framework/*": ["./src/*"],
      "@parton/cms": ["../cms/index.ts"],
      "@parton/cms/*": ["../cms/src/*"],
      "@parton/copies": ["../copies/index.ts"],
      "@parton/copies/*": ["../copies/src/*"]
